<div class="mb-6 flex items-center justify-between">
  <div>
    <h2 class="text-2xl font-bold text-[#0a1f3d]">Editar afiliada</h2>
    <p class="text-sm text-gray-400 mt-0.5"><%= @affiliate.full_name %></p>
  </div>
  <%= link_to "← Cancelar", admin_affiliate_path(@affiliate),
      class: "rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:border-gray-400 transition-colors" %>
</div>

<% if @affiliate.errors.any? %>
  <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-4">
    <p class="text-sm font-semibold text-red-700">Por favor, corrija os erros abaixo:</p>
    <ul class="mt-2 space-y-1">
      <% @affiliate.errors.full_messages.each do |msg| %>
        <li class="text-sm text-red-600">• <%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 md:p-8">
  <%= form_with model: [:admin, @affiliate], class: "space-y-6" do |f| %>

    <%# Dados pessoais %>
    <div>
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Dados Pessoais</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <%= f.label :full_name, "Nome completo", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :full_name, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :cpf, "CPF", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :cpf, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.email_field :email, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :whatsapp, "WhatsApp", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :whatsapp, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :tiktok, "TikTok", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :tiktok, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
      </div>
    </div>

    <hr class="border-gray-100">

    <%# Endereço %>
    <div>
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Endereço</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <%= f.label :zip_code, "CEP", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :zip_code, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div class="md:col-span-3">
          <%= f.label :street, "Rua / Logradouro", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :street, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :number, "Número", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :number, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :complement, "Complemento", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :complement,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div class="md:col-span-2">
          <%= f.label :neighborhood, "Bairro", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :neighborhood, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div class="md:col-span-3">
          <%= f.label :city, "Cidade", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :city, required: true,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c]" %>
        </div>
        <div>
          <%= f.label :state, "Estado", class: "block text-sm font-semibold text-[#0a1f3d] mb-1" %>
          <%= f.text_field :state, required: true, maxlength: 2,
              class: "mt-1 block w-full rounded-xl border border-gray-200 px-4 py-3 text-gray-900 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#c9a84c] uppercase" %>
        </div>
      </div>
    </div>

    <%# Ações %>
    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to "Cancelar", admin_affiliate_path(@affiliate),
          class: "rounded-xl border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-600 hover:border-gray-400 transition-colors" %>
      <%= f.submit "Salvar alterações",
          class: "rounded-xl bg-[#0a1f3d] px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-[#0a1f3d]/90 transition-colors cursor-pointer" %>
    </div>

  <% end %>
</div>
